# ============================================================
# Six-Country Info Insights - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ----------------------------------------------------------
# Google Cloud / Gemini AI (required for AI summarisation)
# ----------------------------------------------------------
# Your Google Cloud project ID (e.g., my-project-123456)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Path to service account JSON file (local development)
# GOOGLE_SA_FILE=path/to/service-account.json

# OR: paste full JSON content (CI/CD - stored as GitHub Secret)
# GOOGLE_SA_JSON={"type":"service_account","project_id":"..."}

# ----------------------------------------------------------
# Email SMTP Configuration (optional — for email delivery)
# ----------------------------------------------------------
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
FROM_EMAIL=your-email@gmail.com
TO_EMAIL=recipient@example.com

# ----------------------------------------------------------
# Feishu / Lark Configuration (required for bot delivery)
# Create an app at https://open.feishu.cn/app
# ----------------------------------------------------------
FEISHU_APP_ID=cli_...
FEISHU_APP_SECRET=...

# Optional: your personal Open ID for admin access to generated docs
FEISHU_ADMIN_OPEN_ID=ou_...

# Optional: Folder token to store docs in specific folder
FEISHU_FOLDER_TOKEN=...

# Chat ID(s) for bot push notifications (comma-separated, starts with oc_...)
FEISHU_BOT_CHAT_ID=oc_...
